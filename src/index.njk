---
layout: layouts/base.njk
title: 글 목록
---

<section class="home">
  <h1 class="post-list-heading">Posts</h1>

  {% if collections.postsByDate.length %}
    <ul class="post-list">
      {% for post in collections.postsByDate %}
        <li>
          <a class="post-link" href="{{ post.url }}">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | htmlDateString }}</time>
            <span>{{ post.data.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>아직 쓴 글이 없습니다.</p>
  {% endif %}
</section>
